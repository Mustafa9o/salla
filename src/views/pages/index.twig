        bestsellers: "Bestsellers", check_menu: "CHECK OUT OUR MENU",
        brazilian_coffee: "Brazilian Roasted Coffee", kenyan_coffee: "Kenyan Dark Roast",
        blogs_title: "Featured Blogs", read_more: "Read More →", featured: "Featured",
        menu: "Menu", cafe_locator: "Café Locator", contact: "Contact", contact_desc: "Do you have a <br>question? Send it to <br>us!", privacy: "PRIVACY POLICY",
        your_cart: "Your Cart", empty_cart: "Your cart is empty ☕", total: "Total:", proceed_checkout: "Proceed to Checkout", clear_cart: "Clear Cart", remove: "Remove", qty: "Qty:", add_to_cart: "Add to Cart", sar: "SAR",
        home: "Home", our_products: "Our Products", how_to_brew: "How To Brew", blogs: "Blogs", our_branches: "Our Branches", contact_us: "Contact Us", faqs: "FAQs",
        blog1_title: "The Art of Pour Over", blog1_desc: "Learn how to make the perfect pour over coffee at home with step-by-step guidance.",
        blog2_title: "Espresso vs Drip", blog2_desc: "What is the real difference between these two popular brewing methods?",
        blog3_title: "Coffee Bean Origins", blog3_desc: "Explore the distinct flavors from different coffee-growing regions around the world."
      }
    };

    let currentLang = 'ar'; // Default to Arabic

    function toggleLanguage() {
      currentLang = currentLang === 'ar' ? 'en' : 'ar';
      document.documentElement.lang = currentLang;
      document.documentElement.dir = currentLang === 'ar' ? 'rtl' : 'ltr';
      document.getElementById('lang-toggle').textContent = currentLang === 'ar' ? 'EN' : 'عربي';
      document.getElementById('email-input').placeholder = i18n[currentLang].email_placeholder;
      updateText();
      renderCategories();
      renderProducts();
      renderCart();
    }

    function updateText() {
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (i18n[currentLang][key]) el.innerHTML = i18n[currentLang][key];
      });
    }

    // ANIMATIONS & MENU
    setTimeout(() => document.getElementById('main-content').classList.add('slide-up'), 4700);
    document.getElementById('menu-open-btn').addEventListener('click', () => { document.getElementById('menu-overlay').classList.remove('hidden'); document.getElementById('menu-overlay').classList.add('flex'); });
    document.getElementById('menu-close-btn').addEventListener('click', () => { document.getElementById('menu-overlay').classList.add('hidden'); document.getElementById('menu-overlay').classList.remove('flex'); });

    // CART
    let cart = JSON.parse(localStorage.getItem('ratio_cart') || '[]');
    function saveCart() { localStorage.setItem('ratio_cart', JSON.stringify(cart)); renderCart(); updateBadge(); }
    function updateBadge() {
      const b = document.getElementById('cart-badge');
      const total = cart.reduce((s,i)=>s+(i.quantity||1),0);
      b.textContent = total;
      total > 0 ? (b.classList.remove('hidden'), b.classList.add('flex')) : (b.classList.add('hidden'), b.classList.remove('flex'));
    }
    function renderCart() {
      const list = document.getElementById('cart-items-list');
      const empty = document.getElementById('cart-empty-msg');
      const footer = document.getElementById('cart-footer');
      const assetBase = "{{ 'images/logo.png' | asset }}".replace('logo.png', '');
      if (cart.length === 0) { list.innerHTML = ''; empty.classList.remove('hidden'); footer.classList.add('hidden'); }
      else {
        empty.classList.add('hidden'); footer.classList.remove('hidden');
        list.innerHTML = cart.map(item => `
          <li class="flex justify-between items-start gap-3 border-b pb-3 border-gray-100">
            <div class="flex gap-3 w-[65%]">
              <img src="${assetBase}${item.image}" class="w-12 h-12 object-cover rounded-md border">
              <div class="flex-1">
                <p class="font-bold text-sm leading-tight font-quicksand">${item.title}</p>
                <p class="text-gray-500 text-xs font-quicksand font-bold">${i18n[currentLang].qty} ${item.quantity}</p>
              </div>
            </div>
            <div class="flex flex-col items-end text-left rtl:text-right">
              <span class="text-[#6f4336] font-bold text-sm font-quicksand" dir="ltr">${(item.price * item.quantity).toFixed(2)} ${i18n[currentLang].sar}</span>
              <button onclick="removeFromCart(${item.id})" class="text-xs text-red-500 hover:text-red-700 mt-1 font-quicksand font-bold">${i18n[currentLang].remove}</button>
            </div>
          </li>`).join('');
        document.getElementById('cart-total').textContent = cart.reduce((s,i)=>s+i.price*i.quantity,0).toFixed(2) + ' ' + i18n[currentLang].sar;
      }
    }
    function removeFromCart(id) { cart = cart.filter(i => i.id !== id); saveCart(); }
    function clearCart() { cart = []; saveCart(); }
    document.getElementById('cart-open-btn').addEventListener('click', () => { renderCart(); document.getElementById('cart-overlay').classList.remove('hidden'); document.getElementById('cart-overlay').classList.add('flex'); });
    document.getElementById('cart-close-btn').addEventListener('click', () => { document.getElementById('cart-overlay').classList.add('hidden'); document.getElementById('cart-overlay').classList.remove('flex'); });

    // PRODUCTS
    const allProducts = [
      { id: 1, image: 'pic-1.png', overlay: 'image-11.png', overlayClass: 'top-5 rtl:right-1/2 ltr:left-1/2 rtl:translate-x-1/2 ltr:-translate-x-1/2 w-[254px] h-[254px]', author: 'Amir Samantha', discount: false, price: 18, key: 'brazilian_coffee', cat: 'coffee' },
      { id: 2, image: 'pic-4.png', overlay: null, author: 'John Lennonk', discount: false, price: 22, title_ar: 'روست إثيوبي', title_en: 'Ethiopian Roast', cat: 'roasting' },
      { id: 3, image: 'pic-5.png', overlay: null, author: 'Toekang Sayoer', discount: true, price: 20, title_ar: 'خليط قهوة خاص', title_en: 'Special Coffee Blend', cat: 'special_offers' },
      { id: 4, image: 'pic-3.png', overlay: 'bananers-3d-brown-paper-coffee-bean-bag-transparent-background-a.png', overlayClass: 'top-[30px] rtl:right-[23px] ltr:left-[23px] w-[232px] h-[232px]', author: 'Imelda Saranghae', discount: false, price: 25, title_ar: 'حقيبة قهوة ممتازة', title_en: 'Coffee Bag Premium', cat: 'coffee_equipment' },
    ];
    const cats = ['all_categories', 'special_offers', 'best_seller', 'roasting', 'coffee', 'coffee_equipment'];
    let activeCat = 'all_categories';

    function renderCategories() {
      const nav = document.getElementById('categories-nav');
      nav.innerHTML = '';
      cats.forEach(cat => {
        const btn = document.createElement('button');
        btn.innerHTML = i18n[currentLang][cat];
        btn.className = `relative font-quicksand text-lg sm:text-xl pb-1 transition-all duration-300 ${cat === activeCat ? 'cat-active font-bold text-[#004876]' : 'font-medium text-[#3b2f2f] hover:text-[#004876]'}`;
        btn.onclick = () => { activeCat = cat; renderCategories(); renderProducts(); };
        nav.appendChild(btn);
      });
    }

    function renderProducts() {
      const grid = document.getElementById('products-grid');
      const filtered = activeCat === 'all_categories' ? allProducts : allProducts.filter(p => p.cat === activeCat);
      const assetBase = "{{ 'images/logo.png' | asset }}".replace('logo.png', '');
      grid.innerHTML = filtered.map(p => {
        const t = p.key ? i18n[currentLang][p.key] : (currentLang==='ar'?p.title_ar:p.title_en);
        return `<div><a href="product.html?id=${p.id}" class="block hover:scale-105 transition-transform duration-300">
          <div class="relative w-full h-[250px] sm:h-[300px] mb-3.5 bg-gray-50 rounded-xl overflow-hidden">
            <img class="w-full h-full object-cover" src="${assetBase}${p.image}">
            ${p.overlay ? `<img class="absolute object-cover ${p.overlayClass}" src="${assetBase}${p.overlay}">` : ''}
            ${p.discount ? `<span class="absolute top-[30px] rtl:right-1/2 ltr:left-1/2 rtl:translate-x-1/2 ltr:-translate-x-1/2 bg-[#f9edbd] text-[#3b2f2f] px-2 py-1 text-xs rounded font-bold">-30%</span>` : ''}
          </div>
          <h3 class="font-quicksand font-bold text-[#3b2f2f] text-[20px] sm:text-[22px] text-center mb-1">${t}</h3>
          <p class="font-quicksand font-normal text-[#8b8ba5] text-sm sm:text-base text-center mb-2">${p.author}</p>
          <div class="flex items-center justify-center gap-2">${`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#facc15" stroke="#facc15" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`.repeat(5)}</div>
        </a></div>`;
      }).join('');
    }

    // Initialize
    document.getElementById('email-input').placeholder = i18n.ar.email_placeholder;
    updateText();
    renderCategories();
    renderProducts();
    updateBadge();
  </script>

