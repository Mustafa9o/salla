        <img class="w-[24px] sm:w-[28px] h-[24px] sm:h-[28px]" alt="" src="{{ 'images/group-4.png' | asset }}">
        <span class="font-quicksand font-normal text-[#6f4336] text-xl sm:text-2xl mx-4 sm:mx-6" data-i18n="coffee"></span>
        <img class="w-[24px] sm:w-[28px] h-[24px] sm:h-[28px]" alt="" src="{{ 'images/group-5.png' | asset }}">
