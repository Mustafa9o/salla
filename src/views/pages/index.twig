{% extends "layouts.master" %}

{% block styles %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Infant:ital,wght@0,400;0,600;0,700;1,400&family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">
  <!-- Add Arabic fonts (Cairo) to mix nicely with Quicksand if needed, but Quicksand usually falls back to system Arabic. We'll stick to Quicksand as requested. -->
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">

  <style>
    .intro-container {
      position: fixed; inset: 0; background-color: #fff;
      display: flex; align-items: center; justify-content: center;
      z-index: 9999;
      animation: fadeOut 1s ease-out 3.5s forwards;
    }
    @keyframes fadeOut { to { opacity: 0; visibility: hidden; } }
    .intro-gif { width: 300px; }

    .main-content { opacity: 0; transform: translateY(100vh); transition: transform 2.2s ease-out, opacity 1.5s ease-out; }
    .main-content.slide-up { opacity: 1; transform: translateY(0); }

    .cat-active { font-weight: 600; color: #004876; }
    .cat-active::after { content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 2px; background: #004876; border-radius: 9999px; }

    html[dir="rtl"] .marquee-inner { animation: scrollrtl 25s linear infinite; }
    html[dir="ltr"] .marquee-inner { animation: scroll 25s linear infinite; }

    html[dir="rtl"] .cart-drawer { animation: slideInSideRtl 0.3s ease-out; }
    html[dir="ltr"] .cart-drawer { animation: slideInSide 0.3s ease-out; }
  </style>
{% endblock %}
{% block content %}


  <!-- INTRO -->
  <div class="intro-container">
    <img src="{{ 'images/intro.gif' | asset }}" alt="Loading..." class="intro-gif">
  </div>

  <!-- MAIN -->
  <div class="main-content" id="main-content">

    <!-- HERO SECTION -->
    <section class="relative w-full bg-white overflow-hidden min-h-[90vh] sm:min-h-[95vh] lg:min-h-screen flex flex-col justify-between">

      <!-- NAVBAR -->
      <div class="absolute top-0 left-0 w-full px-4 sm:px-6 md:px-10 py-4 sm:py-6 flex items-center justify-between z-20">
        <a href="index.html">
          <img src="{{ 'images/logo.png' | asset }}" alt="Ratio Coffee Logo" class="w-[80px] sm:w-[100px] md:w-[120px]">
        </a>
        <div class="flex items-center gap-3 sm:gap-5">
          <!-- Language Toggle -->
          <button onclick="toggleLanguage()" id="lang-toggle" class="text-[#004876] hover:text-[#6f4336] font-quicksand font-bold text-lg px-2">
            EN
          </button>
          
          <!-- Cart -->
          <button class="relative text-[#004876] hover:text-[#6f4336] transition-colors" id="cart-open-btn">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 sm:w-7 sm:h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            <span id="cart-badge" class="absolute -top-2 -right-2 bg-[#6f4336] text-white text-xs w-5 h-5 hidden items-center justify-center rounded-full">0</span>
          </button>
          
          <!-- Menu -->
          <button class="text-[#004876] hover:text-[#6f4336] transition-colors" id="menu-open-btn">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 sm:w-7 sm:h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </div>

      <!-- HERO CONTENT -->
      <div class="container mx-auto px-4 sm:px-6 md:px-10 mt-[90px] sm:mt-[120px] md:mt-[140px] lg:mt-[8vw] relative z-10 flex-1 flex items-center">
        <div class="w-full">
          <div class="flex flex-col lg:flex-row items-center justify-between gap-10 lg:gap-12">

            <!-- LEFT: Product image + CTA -->
