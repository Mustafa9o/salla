{# ============================================================ #}
{# HOMEPAGE — pages/index.twig                                  #}
{# Uses Salla Twilight components array to render sections      #}
{# ============================================================ #}
{% extends "layouts.master" %}

{% block title %}{{ store.name }}{% endblock %}
{% block description %}{{ store.description }}{% endblock %}

{% block content %}
    <div class="s-block-container">
        {# Salla automatically renders all homepage components assigned in twilight.json / Theme Editor using this directive #}
        {% component 'home' %}
        <div style="padding: 150px 20px; text-align: center; background: #e0f2fe; margin-top: 100px;">
            <h1 style="color: #004876; font-size: 24px; font-weight: bold; margin-bottom: 20px;">TEST CONTENT IS VISIBLE</h1>
            <p style="color: #333; margin-bottom: 10px;">The global layout (Header and Footer) is working perfectly!</p>
            <p style="color: #333; font-weight: bold;">To build your homepage, go to your Salla Theme Editor and click 'Add New Element' to add the Hero Section and other components to this page!</p>
        </div>
    </div>
{% endblock %}

{% block scripts %}
<script>
  // ===== Intro slide-up (mirrors App.tsx) =====
  // Removed setTimeout to prevent blank screens during editor load

  // ===== Menu open/close =====
  document.getElementById('menu-open-btn')?.addEventListener('click', () => {
    const overlay = document.getElementById('menu-overlay');
    overlay.classList.toggle('hidden');
    overlay.classList.toggle('flex');
  });

  function closeMenu() {
    const overlay = document.getElementById('menu-overlay');
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
  }

  document.getElementById('menu-close-btn')?.addEventListener('click', closeMenu);

  // ===== Category filter (for the custom products list) =====
  function filterByCategory(btn, categoryId) {
    document.querySelectorAll('[data-category]').forEach(b => {
      b.className = 'relative font-quicksand text-xl pb-1 transition-all duration-300 font-normal text-[#3b2f2f] hover:text-[#004876]';
    });
    btn.className = 'relative font-quicksand text-xl pb-1 transition-all duration-300 font-semibold text-[#004876] category-active';

    const grid = document.getElementById('products-grid');
    if(grid) {
      grid.querySelectorAll('[data-product-category]').forEach(card => {
        if (categoryId === 'all' || card.dataset.productCategory === categoryId) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    }
  }
</script>
{% endblock %}

