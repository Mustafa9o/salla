        blog1_title: "فن صب القهوة", blog1_desc: "تعلم كيف تصنع أفضل قهوة مقطرة في المنزل بخطوات بسيطة.",
        blog2_title: "الإسبريسو مقابل المقطرة", blog2_desc: "ما هو الفرق الحقيقي بين أشهر طريقتين لتحضير القهوة؟",
        blog3_title: "أصول حبوب القهوة", blog3_desc: "استكشف النكهات المختلفة من أشهر مناطق زراعة القهوة حول العالم."
      },
      en: {
