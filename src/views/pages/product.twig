{# ============================================================ #}
{# PRODUCT PAGE — pages/product.twig                            #}
{# Mirrors React ProductPage.tsx                                #}
{# ============================================================ #}
{% extends "layouts.master" %}

{% block title %}{{ product.name }} — {{ store.name }}{% endblock %}
{% block description %}{{ product.description | striptags | slice(0,160) }}{% endblock %}

{% block content %}
<div class="min-h-screen bg-white px-4 sm:px-6 md:px-20 py-12 md:py-16 relative">

  {# Sticky Navbar override for product pages #}
  <div class="fixed top-0 left-0 w-full px-4 sm:px-6 md:px-10 py-4 sm:py-6 flex items-center justify-between z-20 bg-white shadow-sm">
    <a href="{{ store.url }}">
      <img src="{{ store.logo }}" alt="{{ store.name }}" class="w-[80px] sm:w-[100px] md:w-[120px] h-auto">
    </a>
    <div class="flex items-center gap-5">
      <salla-cart-summary></salla-cart-summary>
      <button id="menu-open-btn" class="text-[#004876] hover:text-[#6f4336] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>
  {% component 'product.main' %}

  {# Main layout #}
  <div class="flex flex-col lg:flex-row justify-between items-center lg:items-start gap-10 md:gap-16 mt-24 md:mt-28">

    {# LEFT: Product Info #}
    <div class="w-full lg:flex-1 space-y-6 md:space-y-8 text-center lg:text-left">
      <a href="javascript:history.back()" class="text-[#004876] hover:underline flex items-center justify-center lg:justify-start gap-2 font-quicksand">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5m7-7l-7 7 7 7"/></svg>
        {{ trans('common.back') }}
      </a>

      <div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold text-[#4B3A2F] leading-tight font-quicksand">
          {{ product.name }}
        </h1>
        <p class="text-gray-500 text-sm mt-2 font-quicksand">
          {{ trans('pages.product.price_vat_note') }}
        </p>
        <p class="text-2xl sm:text-3xl font-semibold text-[#6f4336] mt-2 font-quicksand">
          {{ product.price }}
        </p>
        {% if product.regular_price and product.sale_price %}
          <p class="text-gray-400 line-through text-base font-quicksand">{{ product.regular_price }}</p>
        {% endif %}
      </div>

      {# Add to Cart + Quantity — Salla handles all the logic #}
      <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
        <salla-quantity-input product-id="{{ product.id }}"></salla-quantity-input>
        <salla-add-product-button
          product-id="{{ product.id }}"
          class="bg-[#004876] hover:bg-[#00385a] text-white px-8 py-3 rounded-full"
        >
          {{ trans('pages.product.add_to_cart') }}
        </salla-add-product-button>
      </div>
    </div>

    {# CENTER: Product Image #}
    <div class="w-full lg:flex-1 flex flex-col items-center justify-center relative order-first lg:order-none mb-8 lg:mb-0">
      <div class="relative w-[280px] sm:w-[320px] md:w-[380px] lg:w-[420px] aspect-square flex items-center justify-center">
        <div class="absolute inset-0 bg-[#004876]/10 rounded-full"></div>
        <img
          src="{{ product.image.url }}"
          alt="{{ product.name }}"
          class="relative z-10 w-[220px] sm:w-[260px] md:w-[300px] lg:w-[340px] h-auto object-contain hover:scale-105 transition-transform duration-300"
        >
      </div>
      {# Wishlist #}
      <salla-favorite
        product-id="{{ product.id }}"
        class="absolute top-6 right-6 bg-white rounded-full p-2 shadow-md"
      ></salla-favorite>
    </div>

    {# RIGHT: Accordion Tabs #}
    <div class="w-full lg:flex-1 space-y-6 border-t lg:border-t-0 lg:border-l border-gray-100 pt-6 lg:pt-0 lg:pl-10">

      {# Description accordion #}
      <div>
        <button onclick="toggleTab('description')" class="flex justify-between items-center w-full text-[#004876] font-medium text-lg font-quicksand border-b border-gray-100 pb-2">
          <span>{{ trans('pages.product.description') }}</span>
          <svg id="chevron-description" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="acc-description" class="hidden py-3">
          <div class="text-gray-700 text-sm leading-relaxed font-quicksand">{{ product.description | raw }}</div>
        </div>
      </div>

      {# Details accordion #}
      <div>
        <button onclick="toggleTab('details')" class="flex justify-between items-center w-full text-[#004876] font-medium text-lg font-quicksand border-b border-gray-100 pb-2">
          <span>{{ trans('pages.product.details') }}</span>
          <svg id="chevron-details" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="acc-details" class="py-3">
          <ul class="text-gray-700 text-sm space-y-1 font-quicksand">
            {% if product.sku %}
              <li><strong>{{ trans('pages.product.sku') }}:</strong> {{ product.sku }}</li>
            {% endif %}
            {% if product.weight %}
              <li><strong>{{ trans('pages.product.weight') }}:</strong> {{ product.weight }}</li>
            {% endif %}
            {% if product.category %}
              <li><strong>{{ trans('pages.product.category') }}:</strong> {{ product.category.name }}</li>
            {% endif %}
            {% for option in product.options | default([]) %}
              <li><strong>{{ option.name }}:</strong> {{ option.values | join(', ') }}</li>
            {% endfor %}
          </ul>
        </div>
      </div>

      {# Salla reviews component #}
      <div class="pt-4">
        <salla-reviews product-id="{{ product.id }}"></salla-reviews>
      </div>

    </div>
  </div>

  {# Related Products #}
  {% if related_products | default([]) | length > 0 %}
    <div class="mt-20">
      <h2 class="text-2xl font-bold text-[#3b2f2f] text-center mb-8 font-quicksand">{{ trans('pages.product.related') }}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-[30px]">
        {% for rp in related_products %}
          {% include 'components/home/product-card' with { product: rp } %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

</div>
{% endblock %}

{% block scripts %}
<script>
  let openTab = 'details';

  function toggleTab(id) {
    const content = document.getElementById('acc-' + id);
    const chevron = document.getElementById('chevron-' + id);

    if (openTab === id) {
      content.classList.add('hidden');
      chevron.classList.remove('rotate-180');
      openTab = null;
    } else {
      if (openTab) {
        document.getElementById('acc-' + openTab).classList.add('hidden');
        document.getElementById('chevron-' + openTab).classList.remove('rotate-180');
      }
      content.classList.remove('hidden');
      chevron.classList.add('rotate-180');
      openTab = id;
    }
  }

  // Menu
  document.getElementById('menu-open-btn')?.addEventListener('click', () => {
    const o = document.getElementById('menu-overlay');
    o.classList.toggle('hidden');
    o.classList.toggle('flex');
  });
  function closeMenu() {
    const o = document.getElementById('menu-overlay');
    o.classList.add('hidden');
    o.classList.remove('flex');
  }
  document.getElementById('menu-close-btn')?.addEventListener('click', closeMenu);
</script>
{% endblock %}
