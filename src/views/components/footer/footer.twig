{# ============================================================ #}
{# FOOTER — components/footer/footer.twig                       #}
{# Mirrors FooterSection.tsx                                     #}
{# ============================================================ #}
<footer class="relative w-full bg-[#004876] py-[60px] sm:py-[78px] px-[20px] sm:px-[60px] lg:px-[113px] overflow-visible">
  <div class="max-w-[1440px] mx-auto flex flex-col lg:flex-row justify-between items-start relative">

    {# Left side content #}
    <div class="flex flex-col z-10 w-full">
      <div class="flex flex-col lg:flex-row gap-[40px] lg:gap-[80px] mb-[50px] lg:mb-[73px] items-start">

        {# Store Logo #}
        <div class="flex-shrink-0">
          <a href="{{ store.url }}">
            <img
              class="w-full max-w-[90px] lg:max-w-[140px] object-contain"
              alt="{{ store.name }}"
              src="{{ store.logo }}"
            >
          </a>
        </div>

        {# Link columns #}
        <div class="flex flex-col sm:flex-row flex-wrap gap-[30px] sm:gap-[60px] lg:gap-[89px] flex-1">

          {# Menu — dynamic store pages #}
          <nav class="flex flex-col gap-[10px]">
            <h3 class="font-cormorant font-semibold text-white text-base sm:text-lg tracking-[1.00px] mb-[5px]">
              {{ trans('blocks.footer.menu') }}
            </h3>
            {% for page in store.pages %}
              <a href="{{ page.url }}" class="font-quicksand font-medium text-[#ffffff95] text-sm sm:text-base hover:text-white transition-colors">
                {{ page.title }}
              </a>
            {% else %}
              <a href="{{ store.url }}products" class="font-quicksand font-medium text-[#ffffff95] text-sm sm:text-base hover:text-white transition-colors">{{ trans('pages.products.title') }}</a>
              <a href="{{ store.url }}blogs" class="font-quicksand font-medium text-[#ffffff95] text-sm sm:text-base hover:text-white transition-colors">{{ trans('pages.blogs.title') }}</a>
              <a href="{{ store.url }}contact-us" class="font-quicksand font-medium text-[#ffffff95] text-sm sm:text-base hover:text-white transition-colors">{{ trans('pages.contact.title') }}</a>
            {% endfor %}
          </nav>

          {# Café Locator — store address #}
          <div class="flex flex-col gap-[10px]">
            <h3 class="font-cormorant font-semibold text-white text-base sm:text-lg mb-[5px]">
              {{ trans('blocks.footer.locator') }}
            </h3>
            <address class="font-quicksand font-medium text-[#ffffff95] text-sm sm:text-base leading-[22px] not-italic max-w-[200px]">
              {{ store.address | default('Al-Hofuf, Al-Salam District 1, Al-Malik Saud Street') }}
            </address>
          </div>

          {# Contact #}
          <div class="flex flex-col gap-[10px]">
            <h3 class="font-cormorant font-semibold text-white text-base sm:text-lg mb-[5px]">
              {{ trans('blocks.footer.contact') }}
            </h3>
            <p class="font-quicksand font-medium text-[#ffffff95] text-sm sm:text-base max-w-[180px]">
              {{ trans('blocks.footer.contact_question') }}
            </p>
            {% if store.phone %}
              <a href="tel:{{ store.phone }}" class="font-bold text-[#ffffff95] text-sm sm:text-base hover:text-white transition-colors font-quicksand">
                {{ store.phone }}
              </a>
            {% endif %}
            {% if store.email %}
              <a href="mailto:{{ store.email }}" class="font-bold text-[#ffffff95] text-sm sm:text-base hover:text-white transition-colors break-all font-quicksand">
                {{ store.email }}
              </a>
            {% endif %}
          </div>

        </div>
      </div>

      <p class="text-[#ffffff95] text-xs sm:text-sm font-quicksand">
        {{ trans('blocks.footer.privacy_policy') }}
      </p>
    </div>

    {# Decorative coffee bag image #}
    <div class="absolute right-[-4px] sm:right-[-40px] bottom-0 translate-y-[20px] sm:translate-y-[30px] z-0 opacity-40 sm:opacity-100">
      <img
        src="{{ 'images/wepik-export-20240121085835p8sy.png' | asset }}"
        alt="{{ trans('blocks.footer.decoration_alt') }}"
        class="w-[220px] sm:w-[320px] md:w-[400px] lg:w-[460px] object-contain drop-shadow-2xl"
      >
    </div>

  </div>
</footer>
