{# ============================================================ #}
{# BESTSELLERS SECTION — components/home/ratio-bestsellers.twig #}
{# ============================================================ #}
<section class="w-full py-12 px-4 overflow-hidden">
  <div class="container mx-auto flex flex-col lg:flex-row items-start gap-12">
    <div class="flex flex-col lg:flex-row items-start gap-6 lg:gap-8">
      <div class="flex flex-col justify-start gap-6 overflow-hidden w-fit">
        <img alt="" src="{{ component.image|default('images/group1000010755.png' | asset) }}" class="object-contain w-[280px] lg:w-[350px]">
      </div>
      <div class="flex flex-col gap-6 mt-20">
        <h2 class="text-3xl font-bold text-[#3b2f2f] tracking-wide font-quicksand">{{ component.title|default(trans('pages.home.bestsellers')) }}</h2>
        <a href="{{ store.url }}products" class="flex items-center gap-2 w-max px-6 py-3 rounded-full border border-[#6f4336] hover:bg-[#6f4336] hover:text-white text-[#6f4336] transition-colors font-quicksand font-normal text-base">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 7l-10 10M7 7h10v10"/></svg>
          {{ trans('pages.home.check_menu') }}
        </a>
      </div>
    </div>
    {# Horizontal scroll of bestseller product cards #}
    <div class="flex-1 overflow-x-auto">
      <div class="flex gap-4 items-start min-w-max">
        {% if products is defined and products|length > 0 %}
          {% for product in products %}
            <a href="{{ product.url }}" class="min-w-[275px] max-w-[275px] h-[392px] overflow-hidden rounded-xl block">
              <div class="w-full h-full bg-cover bg-center flex flex-col justify-between rounded-xl" style="background-image: url('{{ product.image.url }}')">
                <div class="flex justify-end p-3">
                  <salla-favorite product-id="{{ product.id }}"></salla-favorite>
                </div>
                <div class="bg-white/30 backdrop-blur-md px-4 py-5 text-center space-y-2 mt-auto">
                  <h3 class="font-bold text-[#3b2f2f] text-xl mb-1 font-quicksand">{{ product.name }}</h3>
                  <p class="text-[#e1b068] font-bold text-base font-quicksand">{{ product.price }}</p>
                  <salla-add-product-button product-id="{{ product.id }}"></salla-add-product-button>
                </div>
              </div>
            </a>
          {% endfor %}
        {% else %}
          {# Mock Product #}
          {% for i in 1..4 %}
          <a href="#" class="min-w-[275px] max-w-[275px] h-[392px] overflow-hidden rounded-xl block">
            <div class="w-full h-full bg-cover bg-center flex flex-col justify-between rounded-xl hover:scale-105 transition-transform duration-300" style="background-image: url('{{ 'images/r2.jpg' | asset }}')">
              <div class="bg-white/30 backdrop-blur-md px-4 py-5 text-center space-y-2 mt-auto">
                <h3 class="font-bold text-[#3b2f2f] text-xl mb-1 font-quicksand">Ethiopian Roast</h3>
                <p class="text-[#e1b068] font-bold text-base font-quicksand">45 SAR</p>
              </div>
            </div>
          </a>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</section>
