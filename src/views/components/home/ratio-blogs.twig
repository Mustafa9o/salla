{# ============================================================ #}
{# BLOG SECTION — components/home/ratio-blogs.twig              #}
{# ============================================================ #}
<section class="w-full py-20 px-[6.04%] mb-[45px]" id="blogs">
  <h2 class="font-bold text-[#3b2f2f] text-[32px] text-center mb-[84px] font-quicksand">{{ component.title|default(trans('pages.home.blogs_title')) }}</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 justify-items-center max-w-[1200px] mx-auto">
    {% if blogs is defined and blogs|length > 0 %}
      {% for blog in blogs %}
        <a href="{{ blog.url }}" class="group bg-white rounded-lg shadow-md overflow-hidden transition-all duration-300 hover:shadow-xl hover:scale-105 w-full max-w-sm flex flex-col">
          <div class="aspect-video overflow-hidden">
            <img src="{{ blog.image }}" alt="{{ blog.title }}" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" loading="lazy">
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="font-bold text-[#3b2f2f] text-xl mb-3 font-quicksand group-hover:text-[#6f4336] transition-colors">{{ blog.title }}</h3>
            <p class="text-gray-600 text-sm mb-4 flex-grow font-quicksand">{{ blog.description | default('') | slice(0, 100) }}...</p>
            <div class="flex justify-between items-center mt-auto">
              <span class="text-[#004876] font-medium text-sm font-quicksand">{{ trans('pages.home.read_more') }} →</span>
              <span class="px-2 py-1 bg-[#6f4336] text-white text-xs rounded-full font-quicksand">{{ trans('pages.home.featured') }}</span>
            </div>
          </div>
        </a>
      {% endfor %}
    {% else %}
      {# Mock Blog #}
      {% for i in 1..3 %}
      <a href="#" class="group bg-white rounded-lg shadow-md overflow-hidden transition-all duration-300 hover:shadow-xl hover:scale-105 w-full max-w-sm flex flex-col">
        <div class="aspect-video overflow-hidden bg-gray-200">
          <img src="{{ 'images/r1.jpg' | asset }}" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" loading="lazy">
        </div>
        <div class="p-6 flex flex-col flex-grow">
          <h3 class="font-bold text-[#3b2f2f] text-xl mb-3 font-quicksand group-hover:text-[#6f4336] transition-colors">The Perfect Brew</h3>
          <p class="text-gray-600 text-sm mb-4 flex-grow font-quicksand">Discover the secrets to brewing the perfect cup of coffee at home with our simple guide...</p>
          <div class="flex justify-between items-center mt-auto">
            <span class="text-[#004876] font-medium text-sm font-quicksand">Read More →</span>
            <span class="px-2 py-1 bg-[#6f4336] text-white text-xs rounded-full font-quicksand">Featured</span>
          </div>
        </div>
      </a>
      {% endfor %}
    {% endif %}
  </div>
</section>
